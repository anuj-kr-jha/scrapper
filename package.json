{
  "name": "scrap_ts",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon ./index.mjs --ignore '*.json'",
    "preinstall": "npm i -g pm2",
    "start": "node ./index.mjs",
    "logrotate:setup": "pm2 install pm2-logrotate && pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 14 && pm2 set pm2-logrotate:compress true && pm2 set pm2-logrotate:rotateInterval '0 0 * * *'",
    "launch": "npm run logrotate:setup && pm2 start ecosystem.config.cjs",
    "restart": "pm2 restart scrapper",
    "stop": "pm2 stop scrapper",
    "delete": "pm2 delete scrapper",
    "logs": "pm2 logs scrapper",
    "list": "pm2 list",
    "pretty": "prettier --write \"./**/*.{mjs,js,ts,jsx,json}\""
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cheerio": "0.22.0",
    "compression": "^1.7.4",
    "dotenv": "^17.4.2",
    "exceljs": "^4.3.0",
    "express": "^4.18.1",
    "express-rate-limit": "^6.4.0",
    "helmet": "^5.0.2",
    "lowdb": "^1.0.0",
    "morgan": "^1.10.0",
    "node-schedule": "^2.1.0",
    "nth-check": "^2.0.1"
  },
  "type": "module",
  "devDependencies": {
    "prettier": "^2.8.1"
  }
}
