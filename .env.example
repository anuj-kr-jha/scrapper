# copy to .env and fill. .env is gitignored.

# --- server ---
NODE_ENV=dev
HOST=127.0.0.1
PORT=4000
TZ=Asia/Bahrain
UV_THREADPOOL_SIZE=1
CONCURRENCY_LIMIT=10
# one scrape on boot? true (default) = yes; false = only scrape at scheduled repeat_at times
SCRAP_ON_START=true

# --- admin api ---
# token required in `token` header for /admin/* routes
ADMIN_TOKEN=scrap_2022

# --- skip days 0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday ---
SKIP_DAYS=0,6

# --- create post req after scrap ---
CREATE_POST_REQ=true

# --- myfxbook api (free account) ---
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=

# --- postback: where computed signals are POSTed after each session ---
POSTBACK_URL=http://95.111.231.83/api/forex_ssi/myfxbook
